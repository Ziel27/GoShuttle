{
  "name": "goshuttle-backend",
  "version": "1.0.0",
  "description": "GoShuttle — White-labeled cashless ride-tracking backend for gated communities",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --test --test-concurrency=1 tests/api.integration.test.js tests/security.integration.test.js",
    "test:watch": "node --test --test-concurrency=1 --watch tests/api.integration.test.js tests/security.integration.test.js",
    "create:admin": "node scripts/create-admin.js",
    "seed:mock": "node scripts/seed-mock-data.js",
    "reset:drivers": "node scripts/reset-drivers.js",
    "reconcile:capacity": "node scripts/reconcile-capacity.js",
    "migrate:trip-client-sync-index": "node scripts/migrate-trip-client-sync-index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "nodemailer": "^7.0.13",
    "socket.io": "^4.8.1",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "mongodb-memory-server": "^10.3.0",
    "nodemon": "^3.1.9",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.4"
  }
}
